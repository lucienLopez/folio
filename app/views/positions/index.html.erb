<div class="w-full">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Positions</h1>
    <p class="mt-1 text-sm text-gray-500">Current holdings</p>
  </div>

  <div class="table-wrap">
    <table class="min-w-full divide-y divide-gray-200" data-controller="sort">
      <thead class="bg-gray-900">
        <tr>
          <th class="table-th sortable text-left">Name</th>
          <th class="table-th sortable text-left">Kind</th>
          <th class="table-th text-left" data-sort-method="none">ISIN</th>
          <th class="table-th sortable text-right">Shares</th>
          <th class="table-th sortable text-right">Avg Buy Price</th>
          <th class="table-th sortable text-right">Total Invested</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-100">
        <% @positions.each do |position| %>
          <tr class="table-row">
            <td class="table-td font-medium text-gray-900"><%= position.name %></td>
            <td class="table-td"><%= security_kind_badge(position.kind) %></td>
            <td class="table-td font-mono text-sm text-gray-500"><%= position.isin %></td>
            <td class="table-td text-right text-gray-700" data-sort="<%= position.net_shares %>"><%= position.net_shares %></td>
            <td class="table-td text-right text-gray-700" data-sort="<%= position.avg_buy_price_eur %>"><%= number_to_currency(position.avg_buy_price_eur, unit: '€') %></td>
            <td class="table-td text-right font-semibold text-gray-900" data-sort="<%= position.total_invested %>"><%= number_to_currency(position.total_invested, unit: '€') %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
